{% doc %}
  @prompt
    Create a simple, elegant "Build Your Own Gift Box" feature for a luxury romantic Shopify store. Guide customers through 5 clean steps with smooth navigation, a progress bar at the top, and a live summary panel showing selected items and running total.
    
    Step 1 – Choose Your Gift Box: Display selectable gift box style cards (luxury box, romantic box, minimal premium box) with image, name, and price. Single selection only.
    
    Step 2 – Add Gifts to the Box: Show a grid of selectable product cards from categories: candles, chocolates, jewelry, romantic gifts, accessories. Allow multiple selections. Update running total dynamically.
    
    Step 3 – Add a Personal Message: A styled textarea for customers to write a love note or message to be included with the gift. Optional field with character counter.
    
    Step 4 – Choose Gift Wrapping: Display selectable gift wrap option cards (premium wrap, romantic wrap, minimal wrap, luxury ribbon wrap) with image and price. Single selection only.
    
    Step 5 – Assembly Information & Summary: Show message: "To keep prices affordable and allow more customization, your selected items may arrive separately. You can easily assemble the gift box yourself and create a beautiful surprise for your loved one." Show reward badge: "As a thank-you, you will receive a 30% discount on your next gift box purchase." Display full order summary of all selected items with images, names, and prices. Show total price. Include a prominent "Complete Your Gift Box" button that adds all selected products to the Shopify cart at once.
    
    Design: luxury, romantic, minimal aesthetic. Soft colors: cream, blush pink, beige, gold accents. Elegant serif or script fonts for headings. Lots of white space. Smooth animated transitions between steps. Sticky bottom bar on mobile showing current total and next step button. Fully responsive for all screen sizes., after clicking next it will visit to the next step and not going to up ., i want to connect the collection with my choose like for gift box section only gift box will appare then for product all the product collection then warp collection for wrap 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gift-box-builder-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color }} 0%, {{ block.settings.background_gradient_color }} 100%);
    padding: 60px 20px;
    font-family: 'Playfair Display', serif;
  }

  .ai-gift-box-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-gift-box-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-gift-box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 15px;
    font-weight: 400;
    letter-spacing: 1px;
  }

  .ai-gift-box-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    font-weight: 300;
  }

  .ai-gift-box-progress-{{ ai_gen_id }} {
    width: 100%;
    height: 4px;
    background-color: {{ block.settings.progress_bg_color }};
    border-radius: 10px;
    margin-bottom: 40px;
    overflow: hidden;
  }

  .ai-gift-box-progress-bar-{{ ai_gen_id }} {
    height: 100%;
    background: linear-gradient(90deg, {{ block.settings.accent_color }}, {{ block.settings.accent_hover_color }});
    border-radius: 10px;
    transition: width 0.5s ease;
    width: 20%;
  }

  .ai-gift-box-steps-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-bottom: 50px;
    flex-wrap: wrap;
  }

  .ai-gift-box-step-indicator-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background-color: {{ block.settings.step_bg_color }};
    border-radius: 25px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .ai-gift-box-step-indicator-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
  }

  .ai-gift-box-step-number-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
  }

  .ai-gift-box-content-{{ ai_gen_id }} {
    min-height: 500px;
    position: relative;
  }

  .ai-gift-box-step-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .ai-gift-box-step-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .ai-gift-box-step-title-{{ ai_gen_id }} {
    font-size: 32px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0 0 40px;
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .ai-gift-box-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 25px;
    margin-bottom: 40px;
  }

  .ai-gift-box-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 25px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .ai-gift-box-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
  }

  .ai-gift-box-card-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.accent_color }};
    background-color: {{ block.settings.selected_bg_color }};
  }

  .ai-gift-box-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: {{ block.settings.card_border_radius }}px;
    margin-bottom: 15px;
  }

  .ai-gift-box-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.card_border_radius }}px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-gift-box-card-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-gift-box-card-name-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    font-weight: 500;
  }

  .ai-gift-box-card-price-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.accent_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-gift-box-message-area-{{ ai_gen_id }} {
    max-width: 700px;
    margin: 0 auto;
  }

  .ai-gift-box-textarea-{{ ai_gen_id }} {
    width: 100%;
    min-height: 200px;
    padding: 20px;
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    font-size: 16px;
    font-family: 'Playfair Display', serif;
    color: {{ block.settings.text_color }};
    background-color: #ffffff;
    resize: vertical;
    transition: border-color 0.3s ease;
  }

  .ai-gift-box-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-gift-box-char-counter-{{ ai_gen_id }} {
    text-align: right;
    margin-top: 10px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-gift-box-summary-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-gift-box-info-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.info_bg_color }};
    border-left: 4px solid {{ block.settings.accent_color }};
    padding: 25px;
    border-radius: {{ block.settings.card_border_radius }}px;
    margin-bottom: 30px;
  }

  .ai-gift-box-info-text-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 15px;
  }

  .ai-gift-box-reward-badge-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.accent_color }}, {{ block.settings.accent_hover_color }});
    color: #ffffff;
    padding: 15px 25px;
    border-radius: 25px;
    display: inline-block;
    font-size: 16px;
    font-weight: 600;
    margin-top: 10px;
  }

  .ai-gift-box-summary-items-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .ai-gift-box-summary-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 15px 0;
    border-bottom: 1px solid {{ block.settings.progress_bg_color }};
  }

  .ai-gift-box-summary-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-gift-box-summary-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .ai-gift-box-summary-image-placeholder-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    background-color: #f4f4f4;
    border-radius: 8px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-gift-box-summary-image-placeholder-{{ ai_gen_id }} svg {
    width: 30px;
    height: 30px;
    opacity: 0.3;
  }

  .ai-gift-box-summary-details-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-gift-box-summary-name-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0 0 5px;
    font-weight: 500;
  }

  .ai-gift-box-summary-price-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.accent_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-gift-box-total-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 0;
    font-size: 24px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-gift-box-navigation-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .ai-gift-box-btn-{{ ai_gen_id }} {
    padding: 15px 40px;
    border-radius: 30px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    font-family: 'Playfair Display', serif;
  }

  .ai-gift-box-btn-primary-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.accent_color }}, {{ block.settings.accent_hover_color }});
    color: #ffffff;
  }

  .ai-gift-box-btn-primary-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-gift-box-btn-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.text_color }};
    border: 2px solid {{ block.settings.text_color }};
  }

  .ai-gift-box-btn-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.text_color }};
    color: #ffffff;
  }

  .ai-gift-box-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-gift-box-mobile-bar-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #ffffff;
    padding: 15px 20px;
    box-shadow: 0 -4px 15px rgba(0, 0, 0, 0.1);
    z-index: 100;
  }

  .ai-gift-box-mobile-bar-content-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-gift-box-mobile-total-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-gift-box-mobile-btn-{{ ai_gen_id }} {
    padding: 12px 30px;
    border-radius: 25px;
    background: linear-gradient(135deg, {{ block.settings.accent_color }}, {{ block.settings.accent_hover_color }});
    color: #ffffff;
    border: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }

  .ai-gift-box-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    font-style: italic;
  }

  @media screen and (max-width: 768px) {
    .ai-gift-box-builder-{{ ai_gen_id }} {
      padding: 40px 15px 100px;
    }

    .ai-gift-box-title-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-gift-box-step-title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-gift-box-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-gift-box-navigation-{{ ai_gen_id }} {
      display: none;
    }

    .ai-gift-box-mobile-bar-{{ ai_gen_id }} {
      display: block;
    }

    .ai-gift-box-steps-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<gift-box-builder-{{ ai_gen_id }} class="ai-gift-box-builder-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gift-box-container-{{ ai_gen_id }}">
    <div class="ai-gift-box-header-{{ ai_gen_id }}">
      <h1 class="ai-gift-box-title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h1>
      <p class="ai-gift-box-subtitle-{{ ai_gen_id }}">{{ block.settings.main_subtitle }}</p>
    </div>

    <div class="ai-gift-box-progress-{{ ai_gen_id }}">
      <div class="ai-gift-box-progress-bar-{{ ai_gen_id }}" data-progress-bar></div>
    </div>

    <div class="ai-gift-box-steps-{{ ai_gen_id }}">
      <div class="ai-gift-box-step-indicator-{{ ai_gen_id }} active" data-step-indicator="1">
        <span class="ai-gift-box-step-number-{{ ai_gen_id }}">1</span>
        <span>Gift Box</span>
      </div>
      <div class="ai-gift-box-step-indicator-{{ ai_gen_id }}" data-step-indicator="2">
        <span class="ai-gift-box-step-number-{{ ai_gen_id }}">2</span>
        <span>Add Gifts</span>
      </div>
      <div class="ai-gift-box-step-indicator-{{ ai_gen_id }}" data-step-indicator="3">
        <span class="ai-gift-box-step-number-{{ ai_gen_id }}">3</span>
        <span>Message</span>
      </div>
      <div class="ai-gift-box-step-indicator-{{ ai_gen_id }}" data-step-indicator="4">
        <span class="ai-gift-box-step-number-{{ ai_gen_id }}">4</span>
        <span>Wrapping</span>
      </div>
      <div class="ai-gift-box-step-indicator-{{ ai_gen_id }}" data-step-indicator="5">
        <span class="ai-gift-box-step-number-{{ ai_gen_id }}">5</span>
        <span>Summary</span>
      </div>
    </div>

    <div class="ai-gift-box-content-{{ ai_gen_id }}">
      <div class="ai-gift-box-step-{{ ai_gen_id }} active" data-step="1">
        <h2 class="ai-gift-box-step-title-{{ ai_gen_id }}">Choose Your Gift Box</h2>
        <div class="ai-gift-box-grid-{{ ai_gen_id }}">
          {% if block.settings.box_collection != blank %}
            {% for product in block.settings.box_collection.products limit: block.settings.box_limit %}
              <div class="ai-gift-box-card-{{ ai_gen_id }}" data-box-card data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-price="{{ product.price }}" data-name="{{ product.title }}" data-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 400 }}{% endif %}">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" class="ai-gift-box-card-image-{{ ai_gen_id }}" loading="lazy">
                {% else %}
                  <div class="ai-gift-box-card-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                <h3 class="ai-gift-box-card-name-{{ ai_gen_id }}">{{ product.title }}</h3>
                <p class="ai-gift-box-card-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              </div>
            {% endfor %}
          {% else %}
            <div class="ai-gift-box-empty-state-{{ ai_gen_id }}">
              Select a gift box collection in the block settings
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-gift-box-step-{{ ai_gen_id }}" data-step="2">
        <h2 class="ai-gift-box-step-title-{{ ai_gen_id }}">Add Gifts to Your Box</h2>
        <div class="ai-gift-box-grid-{{ ai_gen_id }}">
          {% if block.settings.gift_collection != blank %}
            {% for product in block.settings.gift_collection.products limit: block.settings.gift_limit %}
              <div class="ai-gift-box-card-{{ ai_gen_id }}" data-gift-card data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-price="{{ product.price }}" data-name="{{ product.title }}" data-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 400 }}{% endif %}">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" class="ai-gift-box-card-image-{{ ai_gen_id }}" loading="lazy">
                {% else %}
                  <div class="ai-gift-box-card-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                <h3 class="ai-gift-box-card-name-{{ ai_gen_id }}">{{ product.title }}</h3>
                <p class="ai-gift-box-card-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              </div>
            {% endfor %}
          {% else %}
            <div class="ai-gift-box-empty-state-{{ ai_gen_id }}">
              Select a gift products collection in the block settings
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-gift-box-step-{{ ai_gen_id }}" data-step="3">
        <h2 class="ai-gift-box-step-title-{{ ai_gen_id }}">Add a Personal Message</h2>
        <div class="ai-gift-box-message-area-{{ ai_gen_id }}">
          <textarea 
            class="ai-gift-box-textarea-{{ ai_gen_id }}" 
            placeholder="{{ block.settings.message_placeholder }}"
            maxlength="{{ block.settings.message_max_length }}"
            data-message-input
          ></textarea>
          <div class="ai-gift-box-char-counter-{{ ai_gen_id }}">
            <span data-char-count>0</span> / {{ block.settings.message_max_length }} characters
          </div>
        </div>
      </div>

      <div class="ai-gift-box-step-{{ ai_gen_id }}" data-step="4">
        <h2 class="ai-gift-box-step-title-{{ ai_gen_id }}">Choose Gift Wrapping</h2>
        <div class="ai-gift-box-grid-{{ ai_gen_id }}">
          {% if block.settings.wrap_collection != blank %}
            {% for product in block.settings.wrap_collection.products limit: block.settings.wrap_limit %}
              <div class="ai-gift-box-card-{{ ai_gen_id }}" data-wrap-card data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-price="{{ product.price }}" data-name="{{ product.title }}" data-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 400 }}{% endif %}">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" class="ai-gift-box-card-image-{{ ai_gen_id }}" loading="lazy">
                {% else %}
                  <div class="ai-gift-box-card-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                <h3 class="ai-gift-box-card-name-{{ ai_gen_id }}">{{ product.title }}</h3>
                <p class="ai-gift-box-card-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              </div>
            {% endfor %}
          {% else %}
            <div class="ai-gift-box-empty-state-{{ ai_gen_id }}">
              Select a gift wrapping collection in the block settings
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-gift-box-step-{{ ai_gen_id }}" data-step="5">
        <h2 class="ai-gift-box-step-title-{{ ai_gen_id }}">Your Gift Box Summary</h2>
        <div class="ai-gift-box-summary-{{ ai_gen_id }}">
          <div class="ai-gift-box-info-box-{{ ai_gen_id }}">
            <p class="ai-gift-box-info-text-{{ ai_gen_id }}">{{ block.settings.assembly_message }}</p>
            <div class="ai-gift-box-reward-badge-{{ ai_gen_id }}">{{ block.settings.reward_message }}</div>
          </div>

          <div class="ai-gift-box-summary-items-{{ ai_gen_id }}" data-summary-container>
          </div>

          <div class="ai-gift-box-total-{{ ai_gen_id }}">
            <span>Total:</span>
            <span data-total-price>{{ 0 | money }}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="ai-gift-box-navigation-{{ ai_gen_id }}">
      <button class="ai-gift-box-btn-{{ ai_gen_id }} ai-gift-box-btn-secondary-{{ ai_gen_id }}" data-prev-btn style="display: none;">Previous</button>
      <button class="ai-gift-box-btn-{{ ai_gen_id }} ai-gift-box-btn-primary-{{ ai_gen_id }}" data-next-btn>Next Step</button>
      <button class="ai-gift-box-btn-{{ ai_gen_id }} ai-gift-box-btn-primary-{{ ai_gen_id }}" data-complete-btn style="display: none;">Complete Your Gift Box</button>
    </div>
  </div>

  <div class="ai-gift-box-mobile-bar-{{ ai_gen_id }}">
    <div class="ai-gift-box-mobile-bar-content-{{ ai_gen_id }}">
      <div class="ai-gift-box-mobile-total-{{ ai_gen_id }}">
        Total: <span data-mobile-total>{{ 0 | money }}</span>
      </div>
      <button class="ai-gift-box-mobile-btn-{{ ai_gen_id }}" data-mobile-next>Next Step</button>
    </div>
  </div>
</gift-box-builder-{{ ai_gen_id }}>

<script>
(function() {
  class GiftBoxBuilder{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentStep = 1;
      this.totalSteps = 5;
      this.selections = {
        box: null,
        gifts: [],
        message: '',
        wrap: null
      };
    }

    connectedCallback() {
      this.steps = this.querySelectorAll('[data-step]');
      this.stepIndicators = this.querySelectorAll('[data-step-indicator]');
      this.progressBar = this.querySelector('[data-progress-bar]');
      this.prevBtn = this.querySelector('[data-prev-btn]');
      this.nextBtn = this.querySelector('[data-next-btn]');
      this.completeBtn = this.querySelector('[data-complete-btn]');
      this.mobileNextBtn = this.querySelector('[data-mobile-next]');
      this.totalPriceEl = this.querySelector('[data-total-price]');
      this.mobileTotalEl = this.querySelector('[data-mobile-total]');
      this.summaryContainer = this.querySelector('[data-summary-container]');
      this.messageInput = this.querySelector('[data-message-input]');
      this.charCount = this.querySelector('[data-char-count]');

      this.setupEventListeners();
      this.updateProgress();
    }

    setupEventListeners() {
      this.querySelectorAll('[data-box-card]').forEach(card => {
        card.addEventListener('click', () => this.selectBox(card));
      });

      this.querySelectorAll('[data-gift-card]').forEach(card => {
        card.addEventListener('click', () => this.toggleGift(card));
      });

      this.querySelectorAll('[data-wrap-card]').forEach(card => {
        card.addEventListener('click', () => this.selectWrap(card));
      });

      if (this.messageInput) {
        this.messageInput.addEventListener('input', (e) => {
          this.selections.message = e.target.value;
          if (this.charCount) {
            this.charCount.textContent = e.target.value.length;
          }
        });
      }

      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', () => this.previousStep());
      }

      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', () => this.nextStep());
      }

      if (this.mobileNextBtn) {
        this.mobileNextBtn.addEventListener('click', () => this.nextStep());
      }

      if (this.completeBtn) {
        this.completeBtn.addEventListener('click', () => this.completeGiftBox());
      }
    }

    selectBox(card) {
      this.querySelectorAll('[data-box-card]').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      this.selections.box = this.getCardData(card);
      this.updateTotal();
    }

    toggleGift(card) {
      const isSelected = card.classList.contains('selected');
      if (isSelected) {
        card.classList.remove('selected');
        const productId = card.dataset.productId;
        this.selections.gifts = this.selections.gifts.filter(g => g.productId !== productId);
      } else {
        card.classList.add('selected');
        this.selections.gifts.push(this.getCardData(card));
      }
      this.updateTotal();
    }

    selectWrap(card) {
      this.querySelectorAll('[data-wrap-card]').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      this.selections.wrap = this.getCardData(card);
      this.updateTotal();
    }

    getCardData(card) {
      return {
        productId: card.dataset.productId,
        variantId: card.dataset.variantId,
        price: parseFloat(card.dataset.price),
        name: card.dataset.name,
        image: card.dataset.image
      };
    }

    updateTotal() {
      let total = 0;
      if (this.selections.box) total += this.selections.box.price;
      this.selections.gifts.forEach(gift => total += gift.price);
      if (this.selections.wrap) total += this.selections.wrap.price;

      const formattedTotal = this.formatMoney(total);
      if (this.totalPriceEl) this.totalPriceEl.textContent = formattedTotal;
      if (this.mobileTotalEl) this.mobileTotalEl.textContent = formattedTotal;
    }

    formatMoney(cents) {
      return '{{ 0 | money }}'.replace('0.00', (cents / 100).toFixed(2));
    }

    nextStep() {
      if (this.currentStep < this.totalSteps) {
        this.currentStep++;
        this.updateStepDisplay();
        this.updateProgress();
        
        if (this.currentStep === 5) {
          this.renderSummary();
        }
      }
    }

    previousStep() {
      if (this.currentStep > 1) {
        this.currentStep--;
        this.updateStepDisplay();
        this.updateProgress();
      }
    }

    updateStepDisplay() {
      this.steps.forEach((step, index) => {
        if (index + 1 === this.currentStep) {
          step.classList.add('active');
        } else {
          step.classList.remove('active');
        }
      });

      this.stepIndicators.forEach((indicator, index) => {
        if (index + 1 <= this.currentStep) {
          indicator.classList.add('active');
        } else {
          indicator.classList.remove('active');
        }
      });

      if (this.prevBtn) {
        this.prevBtn.style.display = this.currentStep > 1 ? 'block' : 'none';
      }

      if (this.nextBtn && this.completeBtn) {
        if (this.currentStep === this.totalSteps) {
          this.nextBtn.style.display = 'none';
          this.completeBtn.style.display = 'block';
          if (this.mobileNextBtn) {
            this.mobileNextBtn.textContent = 'Complete Gift Box';
          }
        } else {
          this.nextBtn.style.display = 'block';
          this.completeBtn.style.display = 'none';
          if (this.mobileNextBtn) {
            this.mobileNextBtn.textContent = 'Next Step';
          }
        }
      }
    }

    updateProgress() {
      const progress = (this.currentStep / this.totalSteps) * 100;
      if (this.progressBar) {
        this.progressBar.style.width = progress + '%';
      }
    }

    renderSummary() {
      if (!this.summaryContainer) return;

      let html = '';
      const allItems = [];

      if (this.selections.box) allItems.push(this.selections.box);
      allItems.push(...this.selections.gifts);
      if (this.selections.wrap) allItems.push(this.selections.wrap);

      allItems.forEach(item => {
        html += `
          <div class="ai-gift-box-summary-item-{{ ai_gen_id }}">
            ${item.image ? 
              `<img src="${item.image}" alt="${item.name}" class="ai-gift-box-summary-image-{{ ai_gen_id }}" loading="lazy">` :
              `<div class="ai-gift-box-summary-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>`
            }
            <div class="ai-gift-box-summary-details-{{ ai_gen_id }}">
              <h4 class="ai-gift-box-summary-name-{{ ai_gen_id }}">${item.name}</h4>
              <p class="ai-gift-box-summary-price-{{ ai_gen_id }}">${this.formatMoney(item.price)}</p>
            </div>
          </div>
        `;
      });

      this.summaryContainer.innerHTML = html;
    }

    async completeGiftBox() {
      const items = [];
      
      if (this.selections.box) {
        items.push({
          id: this.selections.box.variantId,
          quantity: 1
        });
      }

      this.selections.gifts.forEach(gift => {
        items.push({
          id: gift.variantId,
          quantity: 1
        });
      });

      if (this.selections.wrap) {
        items.push({
          id: this.selections.wrap.variantId,
          quantity: 1
        });
      }

      if (items.length === 0) {
        alert('Please select at least one item for your gift box.');
        return;
      }

      try {
        const formData = {
          items: items
        };

        if (this.selections.message) {
          formData.attributes = {
            'Gift Message': this.selections.message
          };
        }

        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData)
        });

        if (response.ok) {
          window.location.href = '/cart';
        } else {
          alert('There was an error adding items to your cart. Please try again.');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('There was an error adding items to your cart. Please try again.');
      }
    }
  }

  customElements.define('gift-box-builder-{{ ai_gen_id }}', GiftBoxBuilder{{ ai_gen_id }});
})();
</script>

